{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Semust API Documentation",
  "colors": {
    "primary": "#0066FF",
    "light": "#3385FF",
    "dark": "#0052CC"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "authentication"
            ]
          },
          {
            "group": "API Reference",
            "pages": [
              "api-reference/serp",
              "api-reference/keyword-data"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://semust.com/dashboard",
          "icon": "gauge"
        },
        {
          "anchor": "API Access",
          "href": "https://semust.com/api/access",
          "icon": "key"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@semust.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Access",
      "href": "https://semust.com/api/access"
    }
  },
  "footer": {
    "socials": {
      "website": "https://semust.com"
    }
  },
  "api": {
    "baseUrl": "https://data.semust.com/v1"
  }
}
